{
  "name": "epub-exporter",
  "version": "0.0.1",
  "description": "Export Markdown notes as EPUB books from Obsidian.",
  "main": "main.js",
  "scripts": {
    "build": "node esbuild.config.mjs production",
    "dev": "node esbuild.config.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check:pure": "sh -c '! grep -rlE \"from [\\\"'\\'']obsidian[\\\"'\\'']\" src/core src/vendor 2>/dev/null'",
    "lint": "node scripts/check-no-inline-disables.mjs && eslint src",
    "gate": "npm run typecheck && npm test && npm run check:pure && npm run lint && npm run build",
    "version-bump": "node ../tools/release/version-bump.mjs",
    "preflight": "node ../tools/release/preflight.mjs",
    "release": "node ../tools/release/release.mjs"
  },
  "keywords": [
    "obsidian",
    "epub"
  ],
  "author": "Johannes Kaindl",
  "license": "AGPL-3.0-or-later",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "esbuild": "^0.20.0",
    "eslint": "^9.39.5",
    "eslint-plugin-obsidianmd": "^0.4.1",
    "fflate": "^0.8.2",
    "jsdom": "^24.0.0",
    "obsidian": "latest",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.64.0",
    "vitest": "^1.4.0"
  }
}
